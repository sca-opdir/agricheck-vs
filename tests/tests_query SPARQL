### tous les points qui ont un label qui contient "heimtiere"

```
PREFIX schema: <http://schema.org/>
PREFIX : <https://agriculture.ld.admin.ch/inspection/>

SELECT ?point ?label ?lang
WHERE {
  ?point a :InspectionPoint ;
         schema:name ?label .
  
  # On cherche le point qui contient le texte du tooltip (Haltung Heimtiere)
  FILTER (CONTAINS(STR(?label), "Heimtiere"))
  
  BIND(LANG(?label) AS ?lang)
}
ORDER BY ?point
```



### lister les premiers pour inspecter la structure

```
PREFIX : <https://agriculture.ld.admin.ch/inspection/>

SELECT ?propriete ?valeur
WHERE {
  # On prend un point au hasard (ou un identifiant précis)
  ?point a :InspectionPoint .
  ?point ?propriete ?valeur .
}
LIMIT 50
```

### query par numéro d'identifiant PC Acontrol Masterliste

```
PREFIX schema: <http://schema.org/>
PREFIX : <https://agriculture.ld.admin.ch/inspection/>

SELECT ?point ?id ?titreFR ?descriptionFR
WHERE {
  # On cherche l'objet qui a le type InspectionPoint
  ?point a :InspectionPoint ;
         # On filtre par l'identifiant exact que vous avez cité
         :conjunctIdentifier "12.24_2025, E1, 01" .
  
  # On récupère les champs lisibles
  OPTIONAL { 
    ?point schema:name ?titreFR .
    FILTER(LANG(?titreFR) = "fr")
  }
  
  OPTIONAL { 
    ?point schema:description ?descriptionFR .
    FILTER(LANG(?descriptionFR) = "fr")
  }
  
  # On récupère aussi l'ID court pour vérification
  OPTIONAL { ?point schema:identifier ?id . }
}
```

### retrouver le parent 

```
PREFIX schema: <http://schema.org/>
PREFIX : <https://agriculture.ld.admin.ch/inspection/>

SELECT ?point ?idConjunct ?parentURI ?parentNom
WHERE {
  # 1. On identifie notre point précis
  ?point :conjunctIdentifier "12.24_2025, E1, 01" .
  
  # 2. On suit le lien vers le groupe parent
  ?point :belongsToGroup ?parentURI .
  
  # 3. On récupère le nom du parent (en français)
  ?parentURI schema:name ?parentNom .
  FILTER(LANG(?parentNom) = "fr")
  
}
```

### retracer l'ascendance de façon récursive

```
PREFIX schema: <http://schema.org/>
PREFIX : <https://agriculture.ld.admin.ch/inspection/>

SELECT ?parentURI ?nomParent
WHERE {
  # 1. On cible votre point
  ?point :conjunctIdentifier "12.24_2025, E1, 01" .
  
  # 2. On remonte via belongsToGroup OU schema:isPartOf de façon récursive
  # Le symbole | signifie "OU"
  ?point (:belongsToGroup|schema:isPartOf)+ ?parentURI .
  
  # 3. On récupère le nom
  ?parentURI schema:name ?nomParent .
  
  FILTER(LANG(?nomParent) = "fr")
}
```


### trouver tous les éléments qui ont exactement value="Hunde" (mais va chercher vraiment partout)


```
PREFIX schema: <http://schema.org/>

SELECT ?element ?type ?nom ?lang
WHERE {
  ?element schema:name ?nom .
  
  # On filtre pour avoir exactement "Hunde"
  FILTER (STR(?nom) = "Hunde")
  
  # On récupère le type pour savoir si c'est un point ou un groupe
  OPTIONAL { ?element a ?type . }
  
  # On récupère le tag de langue (devrait être @de)
  BIND(LANG(?nom) AS ?lang)
}
```

